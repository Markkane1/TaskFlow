# Server
PORT=3000
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace-with-at-least-32-characters-random-secret
TASKFLOW_DB_PATH=taskflow.db
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=mock
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_REPLY_TO_EMAIL=
RESEND_AUDIENCE_TAG=taskflow
SQLITE_BUSY_TIMEOUT_MS=5000
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL_HOURS=24
DB_BACKUP_DIR=backups
DB_MONITOR_ENABLED=true
DB_MONITOR_INTERVAL_MINUTES=15
SEED_DEFAULT_ADMIN=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
COOKIE_SAME_SITE=strict
COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_MS=43200000
SLA_ESCALATION_MINUTES_AFTER_DEADLINE=60

# Client (used by Vite dev proxy)
VITE_SERVER_URL=http://localhost:3000
