{
  "name": "taskflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsx server/src/main.ts",
    "start": "cross-env NODE_ENV=production tsx server/src/main.ts",
    "build": "vite build --config client/vite.config.ts",
    "preview": "vite preview --config client/vite.config.ts",
    "lint": "tsc --noEmit -p client/tsconfig.json && tsc --noEmit -p server/tsconfig.json",
    "pretest": "node tests/scripts/prepare-test-db.mjs",
    "test": "cross-env NODE_ENV=test TASKFLOW_DB_PATH=tests/.tmp/taskflow.test.db JWT_SECRET=test_jwt_secret_for_ci_and_local_runs_32_chars_min COOKIE_SECURE=false COOKIE_SAME_SITE=strict EMAIL_NOTIFICATIONS_ENABLED=false tsx --test --test-concurrency=1 \"tests/**/*.test.ts\"",
    "test:watch": "cross-env NODE_ENV=test TASKFLOW_DB_PATH=tests/.tmp/taskflow.test.db JWT_SECRET=test_jwt_secret_for_ci_and_local_runs_32_chars_min COOKIE_SECURE=false COOKIE_SAME_SITE=strict EMAIL_NOTIFICATIONS_ENABLED=false tsx --test --watch --test-concurrency=1 \"tests/**/*.test.ts\"",
    "test:typecheck": "tsc --noEmit -p tests/tsconfig.json",
    "test:all": "npm run test:typecheck && npm run test",
    "clean": "rimraf client/dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
